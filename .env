# Frontend API base path. Keep /api so the Vite local middleware can handle requests.
VITE_GLOB_API_URL=/api

# Whether long replies are supported, which may result in higher API fees
VITE_GLOB_OPEN_LONG_REPLY=false

# When you want to use PWA
VITE_GLOB_APP_PWA=false

# Model provider credentials used during build/runtime.
# Switch provider with AI_PROVIDER=deepseek or AI_PROVIDER=siliconflow.

AI_PROVIDER=deepseek

# deepseek
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=sk-7ffc54630e2a43d683f0256c474a1a7f
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_CUSTOM_MODELS=deepseek-v4-flash,deepseek-v4-pro

# siliconflow
SILICONFLOW_API_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_API_KEY=sk-sxalxjwwfwgvmkenrrgxojokvgmpwqukdzqdnteqwwucmtiv
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_CUSTOM_MODELS=deepseek-ai/DeepSeek-V3,deepseek-ai/DeepSeek-R1
